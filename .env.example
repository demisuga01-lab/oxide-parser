# Oxide Server Environment Variables
OXIDE_PORT=8080
OXIDE_LOG_LEVEL=info
OXIDE_MAX_FILE_SIZE=52428800
OXIDE_MAX_DPI=600
OXIDE_MAX_PAGES=200

# --- Authentication (FAIL-CLOSED) ------------------------------------------
# Comma-separated list of valid API keys. Clients authenticate via either
#   X-API-Key: <key>           or        Authorization: Bearer <key>
# Keys are compared in constant time. The /health and /readiness probes are
# always exempt (so load balancers can reach them); all data endpoints require
# a valid key.
#
# FAIL-CLOSED: if this is EMPTY, the server REFUSES TO START unless you also set
# OXIDE_ALLOW_UNAUTHENTICATED=true below. This prevents a forgotten config from
# silently exposing every endpoint. SET THIS before deploying.
OXIDE_API_KEYS=

# Dev-only escape hatch. Set to true to run with NO authentication (every data
# endpoint open). Logs a prominent warning on startup. NEVER set this in
# production — it exists only so local development can skip key setup.
OXIDE_ALLOW_UNAUTHENTICATED=false

# --- CORS (restrictive by default) -----------------------------------------
# Comma-separated allowlist of origins permitted to make cross-origin (browser)
# requests, e.g. https://app.example.com,https://admin.example.com
# EMPTY (default) = no cross-origin access granted (most restrictive). Set this
# to your frontend's origin(s) if a browser app calls the API cross-origin.
OXIDE_CORS_ALLOWED_ORIGINS=

# Dev-only escape hatch mirroring the auth one: set to true to allow ANY origin
# (permissive CORS). Logs a warning on startup. Local development ONLY.
OXIDE_CORS_ALLOW_ANY=false

# --- Rate limiting ---------------------------------------------------------
# Max requests per minute per API key (or per "anonymous" bucket when running
# unauthenticated). 0 disables rate limiting. Exceeding the limit returns 429.
# Per-key buckets are swept by a background cleanup task and bounded by an
# absolute key cap, so memory stays bounded even under key/IP rotation.
OXIDE_RATE_LIMIT_PER_MIN=60

# --- Resource safety (per-request timeout + limits) ------------------------
# Wall-clock budget for the heavy processing phase of a single request, in
# seconds. On timeout the engine cooperatively cancels its hot loops and the
# request returns 503 instead of occupying a worker indefinitely. 0 disables.
OXIDE_REQUEST_TIMEOUT_SECS=30
# Cap on rendered pixels per page (width_px * height_px), checked BEFORE the
# page buffer is allocated. Stops giant-MediaBox "pixel explosion" OOMs. An A4
# page at 600 DPI is ~35 MP; 100 MP leaves generous headroom for real jobs.
OXIDE_MAX_RENDER_PIXELS=100000000
# Cap on total response/ZIP output bytes, enforced as output accumulates.
# Defends against zip-bomb-like input/output asymmetry. Default 2 GiB.
OXIDE_MAX_OUTPUT_BYTES=2147483648
# Cap on the number of images extracted in a single extract-images request.
OXIDE_MAX_IMAGE_COUNT=10000

# --- Async job queue (large-file processing) -------------------------------
# The heavy endpoints have async variants under /api/v1/jobs/... that enqueue a
# background job (202 + job_id), processed by a bounded worker pool, with status
# and result polling. Use them for large/slow inputs that would exceed the sync
# request timeout above; the synchronous endpoints remain for small/fast jobs.
# NOTE: jobs are held IN-MEMORY with results on local disk — single-process
# only (state is lost on restart, no horizontal scaling). See docs/jobs.md.
#
# Number of background worker tasks draining the queue. The work is CPU-bound
# and itself parallel (rayon over pages), so a small pool saturates the machine.
OXIDE_JOB_WORKERS=2
# Bounded queue length. Submissions beyond this (with all workers busy) are
# rejected with 503 + Retry-After rather than accepted as unbounded backlog.
OXIDE_JOB_QUEUE_CAPACITY=128
# Per-JOB wall-clock budget, in seconds. Deliberately larger than the sync
# request timeout: a job isn't holding a connection, so it may run longer. On
# expiry the job is marked failed ("timeout"). 0 disables the per-job timeout.
OXIDE_JOB_TIMEOUT_SECS=300
# How long a completed/failed job and its result file are retained for the
# client to poll/download, in seconds. A background task reaps expired jobs and
# deletes their result files afterward. Default 1 hour.
OXIDE_JOB_RETENTION_SECS=3600
# Backstop cap on total retained jobs. Bounds memory/disk even if submissions
# outpace retention cleanup; at the cap, new submissions get 503.
OXIDE_MAX_JOBS=1000
# Directory for job result files. Unset = a per-process subdir of the system
# temp dir. Set this to a dedicated, writable, bounded volume in production.
# OXIDE_JOB_RESULT_DIR=/var/lib/oxide/jobs

# --- Deploying securely (checklist) ----------------------------------------
# 1. Set OXIDE_API_KEYS to strong, unique key(s). Leave
#    OXIDE_ALLOW_UNAUTHENTICATED unset/false.
# 2. Set OXIDE_CORS_ALLOWED_ORIGINS to your frontend origin(s). Leave
#    OXIDE_CORS_ALLOW_ANY unset/false.
# 3. Set OXIDE_REQUEST_TIMEOUT_SECS and the OXIDE_MAX_* limits to values sized
#    for your workload.
# 4. Terminate TLS in front of the server (reverse proxy / load balancer);
#    Oxide speaks plain HTTP and expects to sit behind one.


